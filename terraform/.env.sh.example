# Copy to terraform/.env.sh (gitignored) and fill in real values.
# Load before running tofu:  set -a && source terraform/.env.sh && set +a

# Linode Object Storage state backend (S3-compatible) — access key pair for a
# key scoped to the homelab-tfstate bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Linode rejects the newer default S3 checksum headers — make the SDK/CLI skip them
AWS_REQUEST_CHECKSUM_CALCULATION=when_required
AWS_RESPONSE_CHECKSUM_VALIDATION=when_required

# Client-side state/plan encryption passphrase — store in a password manager too
TF_VAR_state_passphrase=

# Proxmox API token: user@realm!tokenid=uuid  (e.g. terraform@pve!tf=<uuid>)
TF_VAR_proxmox_api_token=

# Tailscale OAuth client for managing the tailnet policy. Grant it the
# "Policy File" scope (Read + Write) only. From the Tailscale admin console >
# Settings > OAuth clients.
TF_VAR_tailscale_oauth_client_id=
TF_VAR_tailscale_oauth_client_secret=
