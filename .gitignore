# --- OpenTofu / Terraform ---
terraform/.terraform/
# .terraform.lock.hcl IS committed — it pins provider checksums across machines.
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# --- Ansible ---
# vault.yml IS committed (it is encrypted); the plaintext example is not secret.
*.retry
ansible/inventory/10-guests.ini

# --- secrets ---
# Per-tool secrets live in .env.sh files (Terraform: Linode/Proxmox creds;
# Ansible: vault password). Ignore every .env.sh in any dir; only the committed
# .example files are tracked.
.env.sh

# --- misc ---
.DS_Store
*.swp
