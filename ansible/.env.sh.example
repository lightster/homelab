# Copy to ansible/.env.sh (gitignored) and fill in.

# Ansible Vault password; resolved by Ansible's vault_password_file config
# by using the ansible/vault_pass.sh script.
ANSIBLE_VAULT_PASSWORD=

# Tailscale auth key for enrolling tag-owned infrastructure nodes.
# The key must carry tag:infra and tag:subnet-router.
TAILSCALE_INFRA_AUTHKEY=

# Tailscale auth key for enrolling personal, user-owned dev nodes.
# The key should be setup as reusable and non-ephemeral so a rebuilt
# VM re-enrolls without manual login.
TAILSCALE_PERSONAL_AUTHKEY=
