# Copy to ansible/.env.sh (gitignored) and fill in.
# The Makefile host/guests targets source this for you; to run playbooks by hand:
#   set -a && source ansible/.env.sh && set +a

# Ansible Vault password — resolved by ansible/vault_pass.sh (vault_password_file).
ANSIBLE_VAULT_PASSWORD=

# Tailscale auth key (tskey-auth-...) — used only when enrolling a NEW guest onto
# the tailnet. Ephemeral; regenerate ~every 90 days. From the Tailscale admin
# console > Settings > Keys.
TAILSCALE_AUTHKEY=
